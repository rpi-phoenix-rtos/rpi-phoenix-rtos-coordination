From c17cbfebd3c8e2667f3d3b4a0cc33b4eb6096e97 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Witold=20Bo=C5=82t?= <witold.bolt@jit.team>
Date: Thu, 18 Jun 2026 05:18:18 +0200
Subject: [PATCH 10/17] v3dv: Phoenix BO map uses the winsys-returned uncached
 CPU va directly

Phoenix has no V3D kernel DRM driver; the in-process winsys (phoenix_v3d_ioctl)
backs each BO with uncached, flat-MMU-mapped host memory and returns the BO's
already-mapped CPU virtual address as the DRM_V3D_MMAP_BO offset. So on Phoenix
v3dv_bo_map_unsynchronized must use that offset directly rather than calling the
libc mmap() on the inert render-fd, and v3dv_bo_unmap must not munmap it (the
winsys frees it via GEM_CLOSE). #if __phoenix__-guarded; non-Phoenix unchanged.

Part of fixing the device-create noop-job BO-alloc fault; see the coordination
repo doc 2026-06-18-vulkan-v3dv-noop-job-rootcause.md.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 src/broadcom/vulkan/v3dv_bo.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/src/broadcom/vulkan/v3dv_bo.c b/src/broadcom/vulkan/v3dv_bo.c
index 1417dda7212..0b090e4100b 100644
--- a/src/broadcom/vulkan/v3dv_bo.c
+++ b/src/broadcom/vulkan/v3dv_bo.c
@@ -295,6 +295,13 @@ v3dv_bo_map_unsynchronized(struct v3dv_device *device,
       return false;
    }
 
+#if defined(__phoenix__)
+   /* Phoenix has no V3D kernel DRM driver: the in-process winsys (phoenix_v3d_ioctl in
+    * v3d_phoenix_winsys.c) backs every BO with uncached, flat-MMU-mapped host memory and
+    * returns the BO's already-mapped CPU virtual address as map.offset. There is no
+    * separate kernel mmap to perform — use the returned address directly. */
+   bo->map = (void *)(uintptr_t)map.offset;
+#else
    bo->map = mmap(NULL, size, PROT_READ | PROT_WRITE, MAP_SHARED,
                   device->pdevice->render_fd, map.offset);
    if (bo->map == MAP_FAILED) {
@@ -302,6 +309,7 @@ v3dv_bo_map_unsynchronized(struct v3dv_device *device,
                 bo->handle, (long long)map.offset, (uint32_t)bo->size);
       return false;
    }
+#endif
    VG(VALGRIND_MALLOCLIKE_BLOCK(bo->map, bo->size, 0, false));
 
    bo->map_size = size;
@@ -346,7 +354,12 @@ v3dv_bo_unmap(struct v3dv_device *device, struct v3dv_bo *bo)
 {
    assert(bo && bo->map && bo->map_size > 0);
 
+#if defined(__phoenix__)
+   /* The winsys owns the BO's mapping (it is freed by GEM_CLOSE -> ioc_close_bo); the va
+    * here was not produced by libc mmap(), so there is nothing to munmap. */
+#else
    munmap(bo->map, bo->map_size);
+#endif
    VG(VALGRIND_FREELIKE_BLOCK(bo->map, 0));
    bo->map = NULL;
    bo->map_size = 0;
-- 
