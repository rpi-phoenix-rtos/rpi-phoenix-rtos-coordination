From 1407821881f9a30ba95745ff00782d6c35be5ef6 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Witold=20Bo=C5=82t?= <witold.bolt@jit.team>
Date: Sat, 27 Jun 2026 00:08:34 +0200
Subject: [PATCH 15/17] v3dv: 3-stage extent trace for degenerate buffer->image
 copy (#29 triage)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Prior boot: every buffer->image region reaches V3DV as 0x1/1x0, so textures
upload nothing and sample black. vkQuake provably emits >=1x1 (q_max floor), so
the width-zeroing is downstream of vkQuake's region array. Localise the exact
stage:

- vk_cmd_copy.c (the legacy vkCmdCopyBufferToImage -> CmdCopyBufferToImage2
  trampoline, compiled into libv3dv via the src/vulkan/runtime glob): print the
  region extent on input (pRegions) and after the field-by-field copy (region2s),
  plus sizeof both structs. Splits "corrupt before trampoline" / "corrupt in the
  field copy" / "corrupt after, downstream".

- v3dv_meta_copy.c CmdCopyBufferToImage2: expand the tracer to print the full
  region extent (w,h,d) + imageOffset + bufferOffset/rowlen/imgheight AND the
  DESTINATION IMAGE's own created extent (image->vk.extent) + mip0 slice dims —
  so a degenerate image-creation bug is distinguished from a degenerate region.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 src/broadcom/vulkan/v3dv_meta_copy.c | 31 +++++++++++++++++++++-------
 src/vulkan/runtime/vk_cmd_copy.c     | 18 ++++++++++++++++
 2 files changed, 42 insertions(+), 7 deletions(-)

diff --git a/src/broadcom/vulkan/v3dv_meta_copy.c b/src/broadcom/vulkan/v3dv_meta_copy.c
index 3b990ec20d7..a31c2ba1b10 100644
--- a/src/broadcom/vulkan/v3dv_meta_copy.c
+++ b/src/broadcom/vulkan/v3dv_meta_copy.c
@@ -3418,13 +3418,30 @@ v3dv_CmdCopyBufferToImage2(VkCommandBuffer commandBuffer,
        */
       uint32_t batch_size = 1;
 #if defined(__phoenix__)
-      /* Phoenix copy-path tracer (#29): log which buffer->image copy path each upload
-       * takes so the black-texture triage can see whether conchars goes via the TFU
-       * (now implemented in the winsys) or a CL fallback. tiled=%d gates the ver<71 TFU
-       * precondition (copy_buffer_image_tfu returns false for a non-tiled dst). */
-      fprintf(stderr, "v3dv: CmdCopyBufferToImage region %u/%u %ux%u fmt=%u tiled=%d -> trying TFU\n",
-              r, info->regionCount, info->pRegions[r].imageExtent.width,
-              info->pRegions[r].imageExtent.height, image->vk.format, image->tiled);
+      /* Phoenix copy-path tracer (#29): the prior boot showed every region as 0x1 / 1x0
+       * (degenerate), so the copy uploads no pixels and textures sample black. Disambiguate
+       * a real zero-extent from a logging/struct artifact by printing ALL of: region extent
+       * (w,h,d), region imageOffset (x,y,z), and the DESTINATION IMAGE's own created extent
+       * (image->vk.extent) + mip0 slice dims. If the image is 128x128 but the region extent
+       * is 0 -> the VkBufferImageCopy region is built/marshalled wrong (vkQuake side or the
+       * legacy->2 trampoline); if the image itself is 0x1 -> an image-creation bug. */
+      {
+         const struct v3d_resource_slice *s0 = &image->planes[0].slices[
+            info->pRegions[r].imageSubresource.mipLevel];
+         fprintf(stderr, "v3dv: CmdCopyBufferToImage region %u/%u extent=%ux%ux%u off=%d,%d,%d "
+                 "buf(off=%llu rowlen=%u imgh=%u) | IMAGE create=%ux%ux%u type=%u fmt=%u tiled=%d "
+                 "slice0=%ux%u -> trying TFU\n",
+                 r, info->regionCount,
+                 info->pRegions[r].imageExtent.width, info->pRegions[r].imageExtent.height,
+                 info->pRegions[r].imageExtent.depth,
+                 info->pRegions[r].imageOffset.x, info->pRegions[r].imageOffset.y,
+                 info->pRegions[r].imageOffset.z,
+                 (unsigned long long)info->pRegions[r].bufferOffset,
+                 info->pRegions[r].bufferRowLength, info->pRegions[r].bufferImageHeight,
+                 image->vk.extent.width, image->vk.extent.height, image->vk.extent.depth,
+                 image->vk.image_type, image->vk.format, image->tiled,
+                 s0->width, s0->height);
+      }
 #endif
       if (copy_buffer_image_tfu(cmd_buffer, image, buffer, &info->pRegions[r],
                                 false /* to_buffer */)) {
diff --git a/src/vulkan/runtime/vk_cmd_copy.c b/src/vulkan/runtime/vk_cmd_copy.c
index 5b4ef8a28d2..7303a7c47f2 100644
--- a/src/vulkan/runtime/vk_cmd_copy.c
+++ b/src/vulkan/runtime/vk_cmd_copy.c
@@ -24,6 +24,9 @@
 #include "vk_common_entrypoints.h"
 #include "vk_device.h"
 #include "vk_util.h"
+#if defined(__phoenix__)
+#include <stdio.h>   /* #29 triage trampoline trace */
+#endif
 
 VKAPI_ATTR void VKAPI_CALL
 vk_common_CmdCopyBuffer(VkCommandBuffer commandBuffer,
@@ -128,6 +131,21 @@ vk_common_CmdCopyBufferToImage(VkCommandBuffer commandBuffer,
          .imageOffset         = pRegions[r].imageOffset,
          .imageExtent         = pRegions[r].imageExtent,
       };
+#if defined(__phoenix__)
+      /* #29 black-texture triage: this legacy->Copy2 trampoline is the boundary between
+       * vkQuake's region array (proven >=1x1 by q_max) and what V3DV's CmdCopyBufferToImage2
+       * receives (observed 0x1). Print the extent BEFORE (incoming pRegions) and AFTER (the
+       * converted region2s) the field copy: equal+nonzero here but 0 at v3dv = corruption
+       * downstream of this trampoline; 0 already on `in` = upstream (vkQuake/proc-addr); 0
+       * only on `out` = a struct/field mismatch in this very copy. */
+      fprintf(stderr, "vk-trampoline: CmdCopyBufferToImage region %u in=%ux%ux%u out=%ux%ux%u "
+              "(sizeof in=%u out=%u)\n", r,
+              pRegions[r].imageExtent.width, pRegions[r].imageExtent.height,
+              pRegions[r].imageExtent.depth,
+              region2s[r].imageExtent.width, region2s[r].imageExtent.height,
+              region2s[r].imageExtent.depth,
+              (unsigned)sizeof(VkBufferImageCopy), (unsigned)sizeof(VkBufferImageCopy2));
+#endif
    }
 
    VkCopyBufferToImageInfo2 info = {
