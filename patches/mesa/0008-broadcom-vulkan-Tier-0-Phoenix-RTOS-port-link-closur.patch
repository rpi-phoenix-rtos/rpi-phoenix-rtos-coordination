From 7bb8391a52b94af84acb2764dc85dc01f309de37 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Witold=20Bo=C5=82t?= <witold.bolt@jit.team>
Date: Wed, 17 Jun 2026 12:57:14 +0200
Subject: [PATCH 08/17] broadcom/vulkan: Tier-0 Phoenix-RTOS port (link closure
 for RPi4 V3DV)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Make Mesa's V3DV (Vulkan for Broadcom V3D) driver compile + link for
aarch64-phoenix as the first tier of the RPi4 Vulkan port, mirroring the
existing GL gallium port (tools/v3d-driver-port/). Three minimal source edits,
all guarded so upstream/Linux builds are unchanged:

- vulkan/runtime/vk_image.{h,c}: extend the four
  "#if DETECT_OS_LINUX || DETECT_OS_BSD" guards (the vk_image.drm_format_mod
  field decl + its three uses) with "|| defined(__phoenix__)". The V3D driver
  is a Linux-DRM-ABI driver and the Phoenix winsys emulates that ABI, so the
  modifier field must exist; v3dv_image.c accesses it unconditionally. These are
  Vulkan-runtime-only files (the gallium GL build never compiles them), so this
  does NOT perturb the existing GLQuake stack. (A global __phoenix__⇒
  DETECT_OS_LINUX in detect_os.h was rejected: it flipped u_cpu_detect.c onto a
  <sys/auxv.h> path Phoenix lacks and broke the shared core lib.)

- include/renderdoc_app.h: treat __phoenix__/__unix__ like Linux for
  RENDERDOC_CC (was #error "Unknown platform"). Debug-capture header pulled in
  unconditionally by many V3DV TUs.

- broadcom/vulkan/v3dv_device.c: under __phoenix__, bypass the drmGetDevices2
  device scan in enumerate_devices and create the physical device directly with
  an inert render-fd token (the Phoenix winsys routes every v3d ioctl through
  phoenix_v3d_ioctl regardless of fd; there is no /dev/dri node). Also skip the
  fstat() of the (absent) DRM nodes in create_physical_device.

Builds via tools/v3d-driver-port/build-v3dv-phoenix.py: 96 front-end TUs +
generated entrypoints compile, and a vkCreateInstance/EnumeratePhysicalDevices/
CreateDevice harness links to a statically-linked aarch64-phoenix ELF with 0
undefined symbols (nm -u clean). Boot-verification is Tier 1.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 include/renderdoc_app.h           |  2 ++
 src/broadcom/vulkan/v3dv_device.c | 25 +++++++++++++++++++++++++
 src/vulkan/runtime/vk_image.c     |  6 +++---
 src/vulkan/runtime/vk_image.h     |  2 +-
 4 files changed, 31 insertions(+), 4 deletions(-)

diff --git a/include/renderdoc_app.h b/include/renderdoc_app.h
index b2d10c5e2d2..c19305b198f 100644
--- a/include/renderdoc_app.h
+++ b/include/renderdoc_app.h
@@ -39,6 +39,8 @@
 #define RENDERDOC_CC
 #elif defined(__APPLE__)
 #define RENDERDOC_CC
+#elif defined(__phoenix__) || defined(__unix__)
+#define RENDERDOC_CC
 #else
 #error "Unknown platform"
 #endif
diff --git a/src/broadcom/vulkan/v3dv_device.c b/src/broadcom/vulkan/v3dv_device.c
index 2ee6acafc7f..36d89901501 100644
--- a/src/broadcom/vulkan/v3dv_device.c
+++ b/src/broadcom/vulkan/v3dv_device.c
@@ -1400,6 +1400,12 @@ get_device_properties(const struct v3dv_physical_device *device,
 
 }
 
+#if defined(__phoenix__)
+/* Inert render-fd token for the Phoenix winsys (no /dev/dri node). Any value works;
+ * phoenix_v3d_ioctl ignores the fd. Nonzero so it never looks like a closed fd. */
+#define V3DV_PHOENIX_FAKE_RENDER_FD 0x763364 /* 'v3d' */
+#endif
+
 static VkResult
 create_physical_device(struct v3dv_instance *instance,
                        int32_t primary_fd, int32_t render_fd,
@@ -1426,6 +1432,14 @@ create_physical_device(struct v3dv_instance *instance,
    if (result != VK_SUCCESS)
       goto fail;
 
+#if defined(__phoenix__)
+   /* No /dev/dri nodes to stat on Phoenix; the render fd is an inert token routed to
+    * phoenix_v3d_ioctl. Synthesize device ids so init can proceed. */
+   (void)primary_fd;
+   device->has_primary = false;
+   device->has_render = true;
+   device->render_devid = 0;
+#else
    struct stat primary_stat = {0}, render_stat = {0};
    if (fstat(primary_fd, &primary_stat) != 0) {
       result = vk_errorf(instance, VK_ERROR_INITIALIZATION_FAILED,
@@ -1443,6 +1457,7 @@ create_physical_device(struct v3dv_instance *instance,
 
    device->has_render = true;
    device->render_devid = render_stat.st_rdev;
+#endif
 
 #if USE_V3D_SIMULATOR
    device->sim_file = v3d_simulator_init(render_fd);
@@ -1685,6 +1700,15 @@ enumerate_devices(struct vk_instance *vk_instance)
    struct v3dv_instance *instance =
       container_of(vk_instance, struct v3dv_instance, vk);
 
+#if defined(__phoenix__)
+   /* Phoenix-RTOS (RPi4 V3DV port): there is no /dev/dri node and no real libdrm
+    * device enumeration. The Phoenix winsys (tools/v3d-driver-port/) routes every
+    * v3d ioctl through phoenix_v3d_ioctl regardless of fd, so the render fd is an
+    * inert token. Bypass the drmGetDevices2 scan and create the physical device
+    * directly. primary/display fd = -1 (no KMS; the custom /dev/fb0 swapchain at
+    * Tier 4 handles present). See docs/inprogress/2026-06-17-vulkan-v3dv-tier0-progress.md. */
+   return create_physical_device(instance, -1, V3DV_PHOENIX_FAKE_RENDER_FD, -1);
+#else
    /* FIXME: Check for more devices? */
    drmDevicePtr devices[8];
    int max_devices;
@@ -1746,6 +1770,7 @@ enumerate_devices(struct vk_instance *vk_instance)
    drmFreeDevices(devices, max_devices);
 
    return result;
+#endif /* !__phoenix__ */
 }
 
 uint32_t
diff --git a/src/vulkan/runtime/vk_image.c b/src/vulkan/runtime/vk_image.c
index bda7fc77d1b..15db3eec0e0 100644
--- a/src/vulkan/runtime/vk_image.c
+++ b/src/vulkan/runtime/vk_image.c
@@ -23,7 +23,7 @@
 
 #include "vk_image.h"
 
-#if DETECT_OS_LINUX || DETECT_OS_BSD
+#if DETECT_OS_LINUX || DETECT_OS_BSD || defined(__phoenix__) /* Phoenix V3DV: emulates the Linux DRM ABI; keep drm_format_mod */
 #include <drm-uapi/drm_fourcc.h>
 #endif
 
@@ -105,7 +105,7 @@ vk_image_init(struct vk_device *device,
       vk_find_struct_const(pCreateInfo->pNext, WSI_IMAGE_CREATE_INFO_MESA);
    image->wsi_legacy_scanout = wsi_info && wsi_info->scanout;
 
-#if DETECT_OS_LINUX || DETECT_OS_BSD
+#if DETECT_OS_LINUX || DETECT_OS_BSD || defined(__phoenix__) /* Phoenix V3DV: emulates the Linux DRM ABI; keep drm_format_mod */
    image->drm_format_mod = ((1ULL << 56) - 1) /* DRM_FORMAT_MOD_INVALID */;
 #endif
 
@@ -185,7 +185,7 @@ vk_image_destroy(struct vk_device *device,
    vk_object_free(device, alloc, image);
 }
 
-#if DETECT_OS_LINUX || DETECT_OS_BSD
+#if DETECT_OS_LINUX || DETECT_OS_BSD || defined(__phoenix__) /* Phoenix V3DV: emulates the Linux DRM ABI; keep drm_format_mod */
 VKAPI_ATTR VkResult VKAPI_CALL
 vk_common_GetImageDrmFormatModifierPropertiesEXT(UNUSED VkDevice device,
                                                  VkImage _image,
diff --git a/src/vulkan/runtime/vk_image.h b/src/vulkan/runtime/vk_image.h
index f560519c16f..5f03ccd49ef 100644
--- a/src/vulkan/runtime/vk_image.h
+++ b/src/vulkan/runtime/vk_image.h
@@ -77,7 +77,7 @@ struct vk_image {
    /* wsi_image_create_info::scanout */
    bool wsi_legacy_scanout;
 
-#if DETECT_OS_LINUX || DETECT_OS_BSD
+#if DETECT_OS_LINUX || DETECT_OS_BSD || defined(__phoenix__) /* Phoenix V3DV: emulates the Linux DRM ABI; keep drm_format_mod */
    /* VK_EXT_drm_format_modifier
     *
     * Initialized by vk_image_create/init() to DRM_FORMAT_MOD_INVALID.  It's
-- 
