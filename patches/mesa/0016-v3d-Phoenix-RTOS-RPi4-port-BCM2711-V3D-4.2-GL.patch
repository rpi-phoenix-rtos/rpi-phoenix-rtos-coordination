diff --git a/src/gallium/drivers/v3d/v3d_bufmgr.c b/src/gallium/drivers/v3d/v3d_bufmgr.c
index e82fd069b18..0eed759e4e0 100644
--- a/src/gallium/drivers/v3d/v3d_bufmgr.c
+++ b/src/gallium/drivers/v3d/v3d_bufmgr.c
@@ -117,9 +117,18 @@ v3d_bo_from_cache(struct v3d_screen *screen, uint32_t size, const char *name)
 
 struct v3d_bo *
 v3d_bo_alloc(struct v3d_screen *screen, uint32_t size, const char *name)
+{
+        return v3d_bo_alloc_flags(screen, size, name, 0);
+}
+
+struct v3d_bo *
+v3d_bo_alloc_flags(struct v3d_screen *screen, uint32_t size, const char *name,
+                   uint32_t create_flags)
 {
         struct v3d_bo *bo;
         int ret;
+        bool cacheable = (create_flags & V3D_CREATE_BO_CACHEABLE) != 0;
+        bool scanout = (create_flags & V3D_CREATE_BO_SCANOUT) != 0;
 
         /* The CLIF dumping requires that there is no whitespace in the name.
          */
@@ -127,7 +136,9 @@ v3d_bo_alloc(struct v3d_screen *screen, uint32_t size, const char *name)
 
         size = align(size, 4096);
 
-        bo = v3d_bo_from_cache(screen, size, name);
+        /* Cacheable BOs bypass the BO cache so they can never be reused as an
+         * uncached GPU-read buffer (which would silently read stale CPU lines). */
+        bo = (cacheable || scanout) ? NULL : v3d_bo_from_cache(screen, size, name);
         if (bo) {
                 if (dump_stats) {
                         mesa_logd("Allocated %s %dkb from cache:", name, size / 1024);
@@ -147,7 +158,8 @@ v3d_bo_alloc(struct v3d_screen *screen, uint32_t size, const char *name)
         bo->private = true;
 
         struct drm_v3d_create_bo create = {
-                .size = size
+                .size = size,
+                .flags = create_flags
         };
 
  retry:
@@ -167,6 +179,8 @@ v3d_bo_alloc(struct v3d_screen *screen, uint32_t size, const char *name)
 
         bo->handle = create.handle;
         bo->offset = create.offset;
+        bo->cacheable = cacheable;
+        bo->scanout = scanout;
 
         screen->bo_count++;
         screen->bo_size += bo->size;
@@ -277,7 +291,9 @@ v3d_bo_last_unreference_locked_timed(struct v3d_bo *bo, time_t time)
         struct v3d_bo_cache *cache = &screen->bo_cache;
         uint32_t page_index = bo->size / 4096 - 1;
 
-        if (!bo->private) {
+        if (!bo->private || bo->cacheable || bo->scanout) {
+                /* cacheable / scanout BOs must not enter the (uncached) BO cache
+                 * (scanout aliases a fixed framebuffer PA). */
                 v3d_bo_free(bo);
                 return;
         }
@@ -515,13 +531,10 @@ v3d_bo_map_unsynchronized(struct v3d_bo *bo)
                 abort();
         }
 
-        bo->map = mmap(NULL, bo->size, PROT_READ | PROT_WRITE, MAP_SHARED,
-                       bo->screen->fd, offset);
-        if (bo->map == MAP_FAILED) {
-                mesa_loge("mmap of bo %d (offset 0x%016llx, size %d) failed",
-                          bo->handle, (long long)offset, bo->size);
-                abort();
-        }
+        /* Phoenix winsys: BOs are already CPU-mapped (uncached, MAP_CONTIGUOUS) at
+         * CREATE_BO time, and MMAP_BO returns that CPU virtual address as `offset`.
+         * Use it directly — re-mmap()ing our non-device fd would fault/hang. */
+        bo->map = (void *)(uintptr_t)offset;
         VG(VALGRIND_MALLOCLIKE_BLOCK(bo->map, bo->size, 0, false));
 
         return bo->map;
diff --git a/src/gallium/drivers/v3d/v3d_bufmgr.h b/src/gallium/drivers/v3d/v3d_bufmgr.h
index 5363bf92fcb..08325688c74 100644
--- a/src/gallium/drivers/v3d/v3d_bufmgr.h
+++ b/src/gallium/drivers/v3d/v3d_bufmgr.h
@@ -54,10 +54,29 @@ struct v3d_bo {
          * it's safe to reuse it in the BO cache).
          */
         bool private;
+
+        /* Phoenix: CPU mapping is cacheable (vs the default uncached DMA mapping).
+         * Used only for GPU-written / CPU-read-back render targets so the CPU
+         * readback (detile) hits cache instead of crawling uncached DRAM. Such BOs
+         * bypass the BO cache (they must not be reused as uncached GPU-read buffers)
+         * and are invalidated (dc ivac) before each CPU read. */
+        bool cacheable;
+
+        /* Phoenix: BO is backed by the HDMI scanout framebuffer's physical pages
+         * (render-to-scanout) — the GPU stores straight to the displayed surface, so
+         * there is no CPU readback/blit. Like cacheable, such a BO bypasses the BO
+         * cache (it aliases a fixed PA and must never be reused as a generic buffer). */
+        bool scanout;
 };
 
+/* Phoenix: drm_v3d_create_bo.flags bits. */
+#define V3D_CREATE_BO_CACHEABLE (1u << 0)
+#define V3D_CREATE_BO_SCANOUT   (1u << 1)
+
 struct v3d_bo *v3d_bo_alloc(struct v3d_screen *screen, uint32_t size,
                             const char *name);
+struct v3d_bo *v3d_bo_alloc_flags(struct v3d_screen *screen, uint32_t size,
+                                  const char *name, uint32_t create_flags);
 void v3d_bo_last_unreference(struct v3d_bo *bo);
 void v3d_bo_last_unreference_locked_timed(struct v3d_bo *bo, time_t time);
 struct v3d_bo *v3d_bo_open_name(struct v3d_screen *screen, uint32_t name);
