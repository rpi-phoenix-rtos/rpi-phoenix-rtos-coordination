index d639c688637..fefb9046cb9 100644
--- a/src/gallium/drivers/v3d/v3d_context.c
+++ b/src/gallium/drivers/v3d/v3d_context.c
@@ -69,7 +69,10 @@ v3d_pipe_flush(struct pipe_context *pctx, struct pipe_fence_handle **fence,
                  */
                 drmSyncobjExportSyncFile(v3d->fd, v3d->out_sync, &fd);
                 if (fd == -1) {
-                        mesa_loge("Export failed");
+                        /* Bare-metal Phoenix port: no DRM syncobj/sync-file FD export. The
+                         * synchronous winsys submit already guarantees GPU completion, so a
+                         * NULL fence is correct here. Do NOT log — this fires on every flush
+                         * and floods the UART with 100k+ lines, crippling the boot. */
                         *fence = NULL;
                         return;
                 }
diff --git a/src/gallium/drivers/v3d/v3d_resource.c b/src/gallium/drivers/v3d/v3d_resource.c
index 33df0d07be5..9e073a401b1 100644
--- a/src/gallium/drivers/v3d/v3d_resource.c
+++ b/src/gallium/drivers/v3d/v3d_resource.c
@@ -110,8 +110,39 @@ v3d_resource_bo_alloc(struct v3d_resource *rsc)
          */
         uint32_t padding =
                 rsc->base.target == PIPE_BUFFER ? 4 : V3D_TFU_READAHEAD_SIZE;
-        bo = v3d_bo_alloc(v3d_screen(pscreen), rsc->size + padding,
-                          "resource");
+        /* Phoenix: a color render target that is NOT sampled is GPU-written and only
+         * ever CPU-read-back (glReadPixels) — never CPU-written and never GPU-read. Map
+         * it cacheable so the readback detile hits cache instead of crawling uncached
+         * DRAM (the dominant present-path cost). Excludes sampled textures + depth, which
+         * stay uncached so the GPU reads them coherently. Invalidated before CPU read in
+         * v3d_resource_transfer_map. */
+        /* Cacheable-readback for render targets (would cut the uncached glReadPixels
+         * detile, the dominant present-path cost) is DISABLED: making a GPU-rendered RT
+         * BO CPU-cacheable hangs the GPU/render after the first cacheable readback — a
+         * coherency wall (NOT contiguity: the BO is contiguous), pending a focused
+         * deep-dive. Re-enable by setting this to the RENDER_TARGET rule. See
+         * docs/inprogress/2026-06-15-td16-cache-enable-plan.md. */
+        /* Cacheable-readback for the tiled color RT is DISABLED: it works (with dc CIVAC;
+         * dc IVAC is EL1-only and traps at EL0) but gives NO speedup — measured readpx is
+         * identical cached vs uncached (~23ms). The cost is the detile's SCATTERED tiled
+         * read pattern (each output pixel from a non-contiguous tiled address -> no cache-
+         * line reuse), not the uncached read. The FPS lever must move the detile to the GPU
+         * (render-to-scanout / TFU-to-linear, after which a LINEAR CPU read would benefit
+         * from caching). The cacheable infra (v3d_bo_alloc_flags + civac) is kept and proven
+         * for that + the NFS GENET-RX path. See docs/inprogress/2026-06-15-td16-cache-enable-plan.md. */
+        /* Phoenix: the full-screen color RT is forced RASTER (see should_tile). RENDER-TO-
+         * SCANOUT: back it with the HDMI framebuffer's physical pages so the GPU raster-stores
+         * straight to the displayed surface — no per-frame glReadPixels/blit/fb0 CPU copies
+         * (those were the ~25ms readpx bottleneck at 1080p; the 8.3 MB RT exceeds the A72 L2 so
+         * even a cacheable readback is DRAM-bandwidth-bound). The winsys maps GPU VA -> scanout
+         * PA; coherency to the display is the existing per-submit SLCACTL + L2T flush. The
+         * cacheable-readback infra (v3d_bo_alloc_flags + civac) stays proven for the NFS GENET-RX
+         * path. See docs/inprogress/2026-06-15-td16-cache-enable-plan.md. */
+        uint32_t create_flags =
+                ((rsc->base.bind & PIPE_BIND_RENDER_TARGET) &&
+                 rsc->base.width0 >= 1024 && rsc->base.height0 >= 768) ? V3D_CREATE_BO_SCANOUT : 0;
+        bo = v3d_bo_alloc_flags(v3d_screen(pscreen), rsc->size + padding,
+                          "resource", create_flags);
         if (bo) {
                 v3d_bo_unreference(&rsc->bo);
                 rsc->bo = bo;
@@ -256,6 +287,25 @@ v3d_map_usage_prep(struct pipe_context *pctx,
         }
 }
 
+/* Phoenix: invalidate a cacheable BO's CPU cache lines so a following CPU read sees
+ * what the (non-coherent) GPU wrote to DRAM, not stale cache. The BO is page-aligned
+ * and page-sized, so the [base, base+size) range is cache-line aligned (no partial-line
+ * loss); and these BOs are CPU-read-only (never CPU-written), so invalidate is safe.
+ * Requires SCTLR_EL1.UCI=1 (EL0 cache maintenance), set by the kernel. */
+static void
+v3d_bo_invalidate_for_cpu_read(struct v3d_bo *bo)
+{
+        uintptr_t a = (uintptr_t)bo->map;
+        uintptr_t end = a + bo->size;
+        /* Use DC CIVAC (clean+invalidate), NOT DC IVAC: invalidate-only is EL1-privileged
+         * and traps at EL0 even with SCTLR.UCI=1 (UCI gates CVAU/CVAC/CVAP/CIVAC/IVAU, not
+         * IVAC). This BO is CPU-read-only so there are no dirty lines — the clean is a
+         * no-op and CIVAC's invalidate makes the next read fetch the GPU's DRAM data. */
+        for (; a < end; a += 64)
+                __asm__ volatile("dc civac, %0" :: "r"(a) : "memory");
+        __asm__ volatile("dsb ish" ::: "memory");
+}
+
 static void *
 v3d_resource_transfer_map(struct pipe_context *pctx,
                           struct pipe_resource *prsc,
@@ -316,6 +366,11 @@ v3d_resource_transfer_map(struct pipe_context *pctx,
                 goto fail;
         }
 
+        /* Phoenix: for a cacheable readback RT the GPU wrote DRAM non-coherently;
+         * invalidate stale CPU lines so the detile/copy below reads the new pixels. */
+        if ((usage & PIPE_MAP_READ) && rsc->bo->cacheable)
+                v3d_bo_invalidate_for_cpu_read(rsc->bo);
+
         *pptrans = ptrans;
 
         /* Our load/store routines work on entire compressed blocks. */
@@ -847,6 +902,14 @@ v3d_resource_create_with_modifiers(struct pipe_screen *pscreen,
         if (tmpl->bind & PIPE_BIND_SCANOUT)
                 should_tile = false;
 
+        /* Phoenix: force the full-screen color render target to RASTER (linear) so a CPU
+         * readback (glReadPixels) is a fast linear copy instead of the ~23ms scattered
+         * tiled detile. Targeted by display size so small SAMPLED render targets (e.g. the
+         * water warpimage) stay tiled (the TMU needs tiled to sample efficiently). */
+        if ((tmpl->bind & PIPE_BIND_RENDER_TARGET) &&
+            tmpl->width0 >= 1024 && tmpl->height0 >= 768)
+                should_tile = false;
+
         /* No user-specified modifier; determine our own. */
         if (count == 1 && modifiers[0] == DRM_FORMAT_MOD_INVALID) {
                 rsc->tiled = should_tile;
diff --git a/src/gallium/drivers/v3d/v3dx_draw.c b/src/gallium/drivers/v3d/v3dx_draw.c
index 14fb2306026..25f569fd630 100644
--- a/src/gallium/drivers/v3d/v3dx_draw.c
+++ b/src/gallium/drivers/v3d/v3dx_draw.c
@@ -1009,6 +1009,17 @@ v3d_update_job_ez(struct v3d_context *v3d, struct v3d_job *job)
                 job->ez_state = V3D_EZ_DISABLED;
         }
 
+        /* Early-Z (EZ) is ENABLED on this V3D 4.2 port (the normal mesa state machine above
+         * decides per-shader/per-direction; it already disables EZ for FS discard/writes-Z).
+         * EZ was previously force-disabled here because depth-tested steeply-tilted polygons
+         * hung the render — but that hang was a symptom of the L2T flush-completion race
+         * (GFXH-1897): the render fetched the binner's tile-list before the bin-phase L2T flush
+         * had drained. That race is now fixed in the winsys (l2t_flush_wait around the pre-bin
+         * and bin->render flushes, v3d_phoenix_winsys.c). With it fixed, the stalltest renders
+         * 3000 tilted depth-tested EZ-ON frames with 0 wedges, so EZ is re-enabled here — it
+         * early-rejects overdraw (FPS win) and lets stock GL_LEQUAL run without the depth-drain
+         * stall. See docs/inprogress/2026-06-21-v3d-early-z-reenable-plan.md. */
+
         if (job->first_ez_state == V3D_EZ_UNDECIDED &&
             (job->ez_state != V3D_EZ_DISABLED || job->draw_calls_queued == 0))
                 job->first_ez_state = job->ez_state;
diff --git a/src/gallium/drivers/v3d/v3dx_state.c b/src/gallium/drivers/v3d/v3dx_state.c
index 0ce11c17a7e..8ba2a4f64ac 100644
--- a/src/gallium/drivers/v3d/v3dx_state.c
+++ b/src/gallium/drivers/v3d/v3dx_state.c
@@ -558,6 +558,16 @@ v3d_set_framebuffer_state(struct pipe_context *pctx,
 
                 if (desc->swizzle[3] == PIPE_SWIZZLE_1)
                         v3d->blend_dst_alpha_one |= 1 << i;
+
+                /* Phoenix Pi4: do NOT swap R<->B. The plo HDMI framebuffer is configured with RGB
+                 * pixel order (mailbox SET_PIXEL_ORDER=1), which matches the V3D's native 32-bit
+                 * store order — so a color RT, whether the GPU scans it out directly (render-to-
+                 * scanout / page-flip) or it is glReadPixels'd for the CPU-present fallback (which
+                 * copies channels straight through, present_blit() in pl_phoenix_vid.c), already
+                 * lands in display order. An earlier render-to-scanout workaround swapped R<->B
+                 * here; on this fb config that was spurious and rendered the brown Quake world
+                 * blue (HW-verified). Leave swap_color_rb at 0. (A format-agnostic fb would derive
+                 * this from plo's actual pixel order rather than hardcoding it.) */
         }
 
         v3d->dirty |= V3D_DIRTY_FRAMEBUFFER;
diff --git a/src/mesa/state_tracker/st_atom_framebuffer.c b/src/mesa/state_tracker/st_atom_framebuffer.c
index cc5ad3d3cb7..487fa4e44df 100644
--- a/src/mesa/state_tracker/st_atom_framebuffer.c
+++ b/src/mesa/state_tracker/st_atom_framebuffer.c
@@ -124,6 +124,21 @@ st_update_framebuffer_state( struct st_context *st )
 
    st->state.fb_orientation = _mesa_fb_orientation(fb);
 
+#if defined(__phoenix__)
+   /* Phoenix-RTOS Pi4 render-to-scanout: the full-screen user FBO is backed by the HDMI
+    * framebuffer's physical pages (winsys V3D_CREATE_BO_SCANOUT, gated on >=1024x768), so the
+    * GPU stores straight to the displayed surface. That surface is scanned top-down (y-down),
+    * but a user FBO is Y_0_BOTTOM (y-up), which lands the whole frame upside down. Force Y_0_TOP
+    * for the full-screen FBO so Mesa negates the viewport Y (st_atom_viewport.c: scale[1]*=-1)
+    * and the frame renders upright directly into scanout — no extra blit/CPU copy. Gated on
+    * full-screen size (matching the scanout trigger) so small internal FBOs (mipmap generation,
+    * blit fallbacks) keep Y_0_BOTTOM and are not wrongly flipped. Winding is compensated by the
+    * platform layer's glFrontFace(GL_CCW) (Mesa does not auto-invert front-face for Y_0_TOP). */
+   if (st->state.fb_orientation == Y_0_BOTTOM &&
+       fb->Width >= 1024 && fb->Height >= 768)
+      st->state.fb_orientation = Y_0_TOP;
+#endif
+
    /**
     * Quantize the derived default number of samples:
     *
