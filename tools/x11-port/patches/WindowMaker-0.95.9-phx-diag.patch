+/*
+ * Phoenix-RTOS port: build a minimal direct-file FcPattern from a
+ *   phxfile:/abs/path.ttf[:pixelsize=N][:antialias=false]
+ * spec. Only FC_FILE + FC_PIXEL_SIZE are load-bearing for XftFontInfoFill;
+ * FC_INDEX defaults to 0 and FC_ANTIALIAS is honoured if present in the spec.
+ * Returns a pattern (caller owns it) or NULL if the path is empty.
+ */
+static FcPattern *phxFileToFcPattern(const char *spec)
+{
+	FcPattern *pattern;
+	char *work, *path, *opt, *next;
+	double pixelsize = DEFAULT_SIZE > 0 ? (double)DEFAULT_SIZE : 12.0;
+	FcBool antialias = FcTrue;
+
+	work = wstrdup(spec + (sizeof(PHX_FILE_PREFIX) - 1));
+
+	/* The file path runs up to the first option-introducing ':'. */
+	path = work;
+	opt = strchr(work, ':');
+	if (opt)
+		*opt++ = 0;
+
+	if (path[0] == 0) {
+		wfree(work);
+		return NULL;
+	}
+
+	/* Parse the ':'-separated options (pixelsize=, antialias=). */
+	while (opt && opt[0]) {
+		next = strchr(opt, ':');
+		if (next)
+			*next++ = 0;
+		if (strncmp(opt, "pixelsize=", 10) == 0) {
+			pixelsize = atof(opt + 10);
+		} else if (strncmp(opt, "antialias=", 10) == 0) {
+			antialias = (strcasecmp(opt + 10, "false") == 0
+				     || strcmp(opt + 10, "0") == 0) ? FcFalse : FcTrue;
+		}
+		opt = next;
+	}
+
+	pattern = FcPatternCreate();
+	if (pattern) {
+		FcPatternAddString(pattern, FC_FILE, (const FcChar8 *)path);
+		FcPatternAddInteger(pattern, FC_INDEX, 0);
+		FcPatternAddDouble(pattern, FC_PIXEL_SIZE, pixelsize > 0 ? pixelsize : 12.0);
+		FcPatternAddBool(pattern, FC_ANTIALIAS, antialias);
+	}
+
+	wfree(work);
+	return pattern;
+}
