+/*
+==================
+SCR_CaptureFrame -- dump the just-rendered frame to com_gamedir/cap_<idx>.png for
+the deterministic Pi-vs-host comparison harness. Frame-indexed (not auto-numbered)
+so the same index = the same demo moment on every machine.
+==================
+*/
+static int cap_sock = -1;
+
+static int scr_sendAll (int s, const void *buf, size_t len)
+{
+	const char *p = (const char *)buf;
+	size_t off = 0;
+	while (off < len) {
+		int r = send (s, p + off, len - off, 0);
+		if (r <= 0)
+			return -1;
+		off += (size_t)r;
+	}
+	return 0;
+}
+
+static int scr_captureConnect (void)
+{
+	struct sockaddr_in sa;
+	int s = socket (AF_INET, SOCK_STREAM, 0);
+	if (s < 0)
+		return -1;
+	memset (&sa, 0, sizeof(sa));
+	sa.sin_family = AF_INET;
+	sa.sin_port = htons ((unsigned short)scr_capture_port.value);
+	sa.sin_addr.s_addr = inet_addr (scr_capture_host.string);
+	if (connect (s, (struct sockaddr *)&sa, sizeof(sa)) != 0) {
+		close (s);
+		return -1;
+	}
+	return s;
+}
+
+static void SCR_CaptureFrame (int idx)
+{
+	byte	*pix, hdr[18];
+	char	path[MAX_OSPATH];
+	const char *dir;
+	FILE	*f;
+	int	w = glwidth, h = glheight, i, n = glwidth * glheight;
+
+	/* Write directory: scr_capture_dir if set, else com_gamedir. The Pi's
+	 * com_gamedir/com_basedir is broken for writes (resolves to "(null)/id1"),
+	 * so the harness sets scr_capture_dir explicitly (e.g. /nfstest/id1 on the
+	 * Pi, straight onto the fast NFS export). Self-contained 24-bit uncompressed
+	 * TGA writer (BGR, bottom-up) so the byte format is identical on every machine
+	 * — no libpng/com_gamedir dependency. */
+	dir = (scr_capture_dir.string && scr_capture_dir.string[0]) ? scr_capture_dir.string : com_gamedir;
+	q_snprintf (path, sizeof(path), "%s/cap_%04d.tga", dir, idx);
+
+	if (!(pix = (byte *) malloc ((size_t)n * 3)))
+		return;
+	glPixelStorei (GL_PACK_ALIGNMENT, 1);
+	glReadPixels (glx, gly, w, h, GL_RGB, GL_UNSIGNED_BYTE, pix);
+	for (i = 0; i < n; i++) {	/* RGB -> BGR in place */
+		byte t = pix[i*3]; pix[i*3] = pix[i*3+2]; pix[i*3+2] = t;
+	}
+
+	memset (hdr, 0, sizeof(hdr));
+	hdr[2] = 2;                 /* uncompressed true-color */
+	hdr[12] = w & 0xff; hdr[13] = (w >> 8) & 0xff;
+	hdr[14] = h & 0xff; hdr[15] = (h >> 8) & 0xff;
+	hdr[16] = 24;              /* bpp */
+
+	/* TCP sink (Pi): stream [u32 idx][u32 tgalen][TGA bytes] to a host listener,
+	 * which writes cap_<idx>.tga. Bypasses the broken nfs-fs VFS write path. */
+	if (scr_capture_host.string && scr_capture_host.string[0]) {
+		uint32_t rec[2];
+		uint32_t tgalen = (uint32_t)(sizeof(hdr) + (size_t)n * 3);
+		if (cap_sock < 0) {
+			cap_sock = scr_captureConnect ();
+			Con_Printf ("CAPTURE: tcp %s:%d %s\n", scr_capture_host.string,
+				(int)scr_capture_port.value, (cap_sock >= 0) ? "connected" : "FAILED");
+		}
+		if (cap_sock >= 0) {
+			rec[0] = htonl ((uint32_t)idx);
+			rec[1] = htonl (tgalen);
+			if (scr_sendAll (cap_sock, rec, sizeof(rec)) != 0 ||
+			    scr_sendAll (cap_sock, hdr, sizeof(hdr)) != 0 ||
+			    scr_sendAll (cap_sock, pix, (size_t)n * 3) != 0) {
+				Con_Printf ("CAPTURE: tcp send failed at idx=%d\n", idx);
+				close (cap_sock);
+				cap_sock = -1;
+			}
+		}
+		free (pix);
+		return;
+	}
+
+	f = fopen (path, "wb");
+	if (f != NULL) {
+		fwrite (hdr, 1, sizeof(hdr), f);
+		fwrite (pix, 1, (size_t)n * 3, f);
+		fclose (f);
+	}
+	if (idx == 0)
+		Con_Printf ("CAPTURE: dir=%s %s\n", dir, (f != NULL) ? "OK" : "fopen FAILED");
+	free (pix);
+}
+
+
+/*
+==================
+SCR_CaptureTick -- called once per rendered frame from SCR_UpdateScreen (just
+before the buffer swap). Captures every scr_capture-th in-game demo frame and
+quits after scr_capture_max shots.
+==================
+*/
+void SCR_CaptureTick (void)
+{
+	static int frames = 0;
+	static int shots = 0;
+
+	if (scr_capture.value <= 0 || !cls.demoplayback || cls.signon != SIGNONS)
+		return;
+
+	if ((frames++ % (int)scr_capture.value) != 0)
+		return;
+
+	SCR_CaptureFrame (shots);
+	Con_Printf ("CAPTURE: cap_%04d.png (demo t=%.2f)\n", shots, cl.time);
+	shots++;
+
+	if (scr_capture_max.value > 0 && shots >= (int)scr_capture_max.value) {
+		Con_Printf ("CAPTURE: done (%d shots), quitting\n", shots);
+		Cbuf_AddText ("quit\n");
+	}
+}
+
+
 //=============================================================================
 
 
