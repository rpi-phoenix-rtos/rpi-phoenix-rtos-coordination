+			Sys_Printf ("vkvid: SCR_DrawGUI #%d (con_forcedup=%d m_state=%d drawloading=%d)\n",
+			            gui_calls, (int)con_forcedup, (int)m_state, (int)scr_drawloading);
+			gui_calls++;
