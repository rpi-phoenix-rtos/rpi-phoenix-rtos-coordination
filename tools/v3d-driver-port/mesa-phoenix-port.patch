+static void
+v3d_bo_invalidate_for_cpu_read(struct v3d_bo *bo)
+{
+        uintptr_t a = (uintptr_t)bo->map;
+        uintptr_t end = a + bo->size;
+        /* Use DC CIVAC (clean+invalidate), NOT DC IVAC: invalidate-only is EL1-privileged
+         * and traps at EL0 even with SCTLR.UCI=1 (UCI gates CVAU/CVAC/CVAP/CIVAC/IVAU, not
+         * IVAC). This BO is CPU-read-only so there are no dirty lines — the clean is a
+         * no-op and CIVAC's invalidate makes the next read fetch the GPU's DRAM data. */
+        for (; a < end; a += 64)
+                __asm__ volatile("dc civac, %0" :: "r"(a) : "memory");
