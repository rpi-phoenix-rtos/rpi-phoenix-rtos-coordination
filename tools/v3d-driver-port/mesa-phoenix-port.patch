diff --git a/src/broadcom/vulkan/v3dv_queue.c b/src/broadcom/vulkan/v3dv_queue.c
index 2cd6e959137..7ba219409e2 100644
--- a/src/broadcom/vulkan/v3dv_queue.c
+++ b/src/broadcom/vulkan/v3dv_queue.c
@@ -1074,6 +1074,30 @@ queue_handle_job(struct v3dv_queue *queue,
       job->needs_bcl_sync = job->type == V3DV_JOB_TYPE_GPU_CL;
    }
 
+#if defined(__phoenix__)
+   /* Skip a degenerate CL job that has no tile state. A CL job's tile state is
+    * allocated from the frame tiling (layers * tiles_x * tiles_y); when one of
+    * those dimensions is zero the tile-state size is zero and v3dv_bo_alloc()
+    * returns NULL (see v3dv_job_allocate_tile_state / v3d_tile_alloc_sizes).
+    * handle_cl_job() then dereferences job->tile_state->offset and faults. Such a
+    * job (a zero-extent meta copy/clear/blit, or an empty render area) has nothing
+    * for the binner or renderer to do, so dropping it is correct and lets the real
+    * render job in the same submit proceed. Without this guard the no-WSI vkQuake
+    * 2D frame path hit a NULL-tile_state CL job at the first vkQueueSubmit and
+    * Data-Aborted in handle_cl_job (far=0x24 == offsetof v3dv_bo, offset). */
+   if (job->type == V3DV_JOB_TYPE_GPU_CL && job->tile_state == NULL) {
+      static bool warned = false;
+      if (!warned) {
+         mesa_logw("v3dv: skipping degenerate CL job with no tile state "
+                   "(zero-extent frame: w=%u h=%u layers=%u draws=%u)\n",
+                   job->frame_tiling.width, job->frame_tiling.height,
+                   job->frame_tiling.layers, job->draw_count);
+         warned = true;
+      }
+      return VK_SUCCESS;
+   }
+#endif
+
    switch (job->type) {
    case V3DV_JOB_TYPE_GPU_CL:
       return handle_cl_job(queue, job, counter_pass_idx, sync_info, signal_syncs);
